{
  "realm": "health-monitor",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 3600,
  "clients": [
    {
      "clientId": "health-monitor-frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8081/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:8081",
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      }
    },
    {
      "clientId": "health-monitor-swagger",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    }
  ],
  "users": [
    {
      "username": "tester",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Local",
      "lastName": "Tester",
      "email": "tester@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "tester",
          "temporary": false
        }
      ]
    }
  ]
}
